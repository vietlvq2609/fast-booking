{
  "name": "fast-booking",
  "version": "1.0.0",
  "description": "Multi-Tenant Booking & CRM SaaS for local businesses",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.17.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "clean": "turbo clean && rm -rf node_modules",
    "deps": "turbo run deps",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "pnpm --filter @fast-booking/database db:generate",
    "db:migrate": "pnpm --filter @fast-booking/database db:migrate",
    "db:studio": "pnpm --filter @fast-booking/database db:studio"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.7",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "overrides": {},
    "peerDependencyRules": {
      "ignoreMissing": []
    }
  }
}
