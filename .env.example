# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fast_booking
POSTGRES_PORT=5432

# Full Drizzle connection string (used by packages/database and apps/api)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fast_booking"

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
